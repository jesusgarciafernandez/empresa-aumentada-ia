# EditorConfig — coherencia de formato entre editores. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: no recortar espacios finales (dos espacios = salto de línea)
[*.md]
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[*.{json,yml,yaml,cff}]
indent_size = 2

[Makefile]
indent_style = tab
